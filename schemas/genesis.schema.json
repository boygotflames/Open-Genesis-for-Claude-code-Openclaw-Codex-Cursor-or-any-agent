{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://genesis-framework.example/schemas/genesis.schema.json",
  "title": "Genesis Framework Normalized Document",
  "description": "Structural validation for a normalized JSON representation of genesis.md. docs/SPEC.md remains authoritative.",
  "$comment": "This schema validates machine-checkable structure only. It cannot prove repo truth, operator honesty, real-world newest-first discipline, behavioral effectiveness, or local-only lifecycle handling.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "layer1",
    "presentWizard",
    "layer3"
  ],
  "properties": {
    "profile": {
      "$ref": "#/$defs/profile"
    },
    "layer1": {
      "$ref": "#/$defs/layer1"
    },
    "presentWizard": {
      "$ref": "#/$defs/presentWizard"
    },
    "layer3": {
      "$ref": "#/$defs/layer3"
    },
    "extensions": {
      "$ref": "#/$defs/extensions"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "profile": {
            "const": "complex"
          }
        },
        "required": [
          "profile"
        ]
      },
      "then": {
        "properties": {
          "layer1": {
            "required": [
              "ownershipAndInterfaces"
            ]
          }
        }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "contentBlock": {
      "description": "A normalized content block may be a single non-empty string or a non-empty list of strings.",
      "oneOf": [
        {
          "$ref": "#/$defs/nonEmptyString"
        },
        {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      ]
    },
    "dateOrTimestamp": {
      "type": "string",
      "description": "The spec requires a date or timestamp. Format checks help with basic shape only.",
      "anyOf": [
        {
          "format": "date"
        },
        {
          "format": "date-time"
        }
      ]
    },
    "extensions": {
      "type": "object",
      "description": "Project-specific structural extensions beyond the frozen minimum contract. Extensions do not change compliance rules.",
      "additionalProperties": true
    },
    "profile": {
      "type": "string",
      "description": "Optional normalized profile for the sanctioned standard shape, the sanctioned complex shape, or a compliant adapted shape. Profiles are not separate standards.",
      "enum": [
        "standard",
        "complex",
        "adapted"
      ]
    },
    "boundaryDefinition": {
      "type": "object",
      "description": "Normalized representation of the required Layer 1 boundary-definition class.",
      "additionalProperties": false,
      "required": [
        "kind",
        "items"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "system-boundaries",
            "domain-map"
          ]
        },
        "items": {
          "$ref": "#/$defs/nonEmptyStringArray"
        }
      }
    },
    "layer1": {
      "type": "object",
      "description": "Layer 1: Macro Reality. The schema can validate structural classes here, not whether the stated repo reality is accurate, current, or brutally honest.",
      "additionalProperties": false,
      "required": [
        "mission",
        "realityAnchors",
        "boundaryDefinition",
        "invariants",
        "activeRisks",
        "nonGoals"
      ],
      "properties": {
        "mission": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "realityAnchors": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "boundaryDefinition": {
          "$ref": "#/$defs/boundaryDefinition"
        },
        "invariants": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "activeRisks": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "nonGoals": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "ownershipAndInterfaces": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "presentWizardFieldName": {
      "type": "string",
      "enum": [
        "dateOrTimestamp",
        "actor",
        "scope",
        "subsystemsTouched",
        "realityChecked",
        "decisions",
        "changes",
        "verification",
        "crossTeamImpact",
        "openThreads",
        "nextStep"
      ]
    },
    "requiredEntryFields": {
      "type": "array",
      "description": "The schema can confirm the presence of required structural fields. It cannot prove whether real entries are useful, specific, or ordered correctly in practice.",
      "minItems": 9,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/presentWizardFieldName"
      },
      "allOf": [
        {
          "contains": {
            "const": "dateOrTimestamp"
          }
        },
        {
          "contains": {
            "const": "actor"
          }
        },
        {
          "contains": {
            "const": "realityChecked"
          }
        },
        {
          "contains": {
            "const": "decisions"
          }
        },
        {
          "contains": {
            "const": "changes"
          }
        },
        {
          "contains": {
            "const": "verification"
          }
        },
        {
          "contains": {
            "const": "openThreads"
          }
        },
        {
          "contains": {
            "const": "nextStep"
          }
        }
      ],
      "anyOf": [
        {
          "contains": {
            "const": "scope"
          }
        },
        {
          "contains": {
            "const": "subsystemsTouched"
          }
        }
      ]
    },
    "ledgerEntry": {
      "type": "object",
      "description": "A normalized Present Wizard entry. Schema can validate field presence, not entry honesty, verification quality, or whether the ledger is actually maintained newest-first over time.",
      "additionalProperties": false,
      "required": [
        "dateOrTimestamp",
        "actor",
        "realityChecked",
        "decisions",
        "changes",
        "verification",
        "openThreads",
        "nextStep"
      ],
      "anyOf": [
        {
          "required": [
            "scope"
          ]
        },
        {
          "required": [
            "subsystemsTouched"
          ]
        }
      ],
      "properties": {
        "dateOrTimestamp": {
          "$ref": "#/$defs/dateOrTimestamp"
        },
        "actor": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "scope": {
          "$ref": "#/$defs/contentBlock"
        },
        "subsystemsTouched": {
          "$ref": "#/$defs/contentBlock"
        },
        "realityChecked": {
          "$ref": "#/$defs/contentBlock"
        },
        "decisions": {
          "$ref": "#/$defs/contentBlock"
        },
        "changes": {
          "$ref": "#/$defs/contentBlock"
        },
        "verification": {
          "$ref": "#/$defs/contentBlock"
        },
        "crossTeamImpact": {
          "$ref": "#/$defs/contentBlock"
        },
        "openThreads": {
          "$ref": "#/$defs/contentBlock"
        },
        "nextStep": {
          "$ref": "#/$defs/contentBlock"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "presentWizard": {
      "type": "object",
      "description": "Present Wizard is structurally mandatory. Reverse-chronological append-only history is a spec rule, but the schema cannot fully prove chronology or mutation discipline from structure alone.",
      "additionalProperties": false,
      "required": [
        "requiredEntryFields",
        "ledger"
      ],
      "properties": {
        "requiredEntryFields": {
          "$ref": "#/$defs/requiredEntryFields"
        },
        "ledger": {
          "type": "array",
          "description": "Entries are expected to appear newest-first in the normalized representation. Validation here is structural only.",
          "items": {
            "$ref": "#/$defs/ledgerEntry"
          }
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    },
    "layer3": {
      "type": "object",
      "description": "Layer 3: Mini Guide. The schema validates the presence of operational sections, not whether they actually constrain behavior in practice.",
      "additionalProperties": false,
      "required": [
        "readFirst",
        "workingRules",
        "updateProtocol"
      ],
      "properties": {
        "readFirst": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "workingRules": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "updateProtocol": {
          "$ref": "#/$defs/nonEmptyStringArray"
        },
        "extensions": {
          "$ref": "#/$defs/extensions"
        }
      }
    }
  }
}
